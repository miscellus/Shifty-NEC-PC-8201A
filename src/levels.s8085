;
; Tile offset definitions
;

WB equ ((TileWallBrick - Tiles)/10)
CS equ ((TileCrateStone - Tiles)/10)
BK equ ((TileBoxKidDown - Tiles)/10)

;-------------------------------------------------------------------------------
